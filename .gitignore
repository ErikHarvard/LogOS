# Compiled binaries (regenerated by build.sh / the toolchain)
/tiny_host
*.bin
*.o

# eval.la's self-reconstruction (regenerated each run)
/eval_reconstructed.la

# specpipe.la's generated math module (regenerated each run)
/math_generated.la

# strutil_spec.la's generated string-utilities module (regenerated each run)
/strutil_generated.la

# native binaries / artifacts emitted by elf.la, secd.la, codegen.la (regenerated each run)
/secd
/logos_native
/logos_secd
/drm_blue
/live_blue
/logos_program.bin
/logos_source.la
/new_logos_secd.bin
/compiler.bin
/runner
/native_small.bin
/logos_app
/logos_nativert
/native_codegen_out
/native_codegen2_out
/native_codegen3_out
/native_input.la

# autopoiesis.la's medium (generation counter, regenerated each run)
/autopoiesis.gen

# Theourgia rasters (composed/recomposed each run by theourgia*.la)
*.ppm

# Unpublished codices stay local-only; ONLY codices/published/ is tracked.
# (codices/* ignores direct children but not codices/ itself, so the negation
# below can re-include the published subtree — re-including a child of a fully
# excluded dir is impossible in git.)
codices/*
!codices/published/
phonyms.wav
mathutil.la
