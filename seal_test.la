# ═══════════════════════════════════════════════════════════════════
#  seal_test.la — audit of THE SEALING (LINGUA_ADAMICA.tex def:ontoneologization
#  ~2415: |𝔤_new| ≡ 1, "formal complexity always one"; Ontoetymological Legibility
#  ~2992). Uses canon.la's VERBATIM MONO / COLLAPSE / ETYM / CANON / DEPTH (the real
#  seal machinery) to verify that neologizing two ontoglyphs yields ONE monoglyph
#  (not a coupling), of formal complexity one, whose etymology is recoverable from
#  the single sealed form (autological, not heterological), the collapse being a
#  metacursive fixed point. Pure str/int ops ⇒ byte-identical host == VM.
# ═══════════════════════════════════════════════════════════════════
glyph SEQ = la a. la b. b
glyph TRUE = la t. la f. t
glyph FALSE = la t. la f. f
glyph IF = la c. la t. la f. c(t)(f)("!")
glyph Z = la f. (la x. f(la v. x(x)(v)))(la x. f(la v. x(x)(v)))
glyph MAX = la m. la n. IF(lt(m)(n))(la _. n)(la _. m)
# decomposition algebra (Scott nodes) — VERBATIM from canon.la
glyph PRIM = la nm. la fp. la fs. la fc. la fd. la fo. la fm. fp(nm)
glyph SYN  = la a. la b. la fp. la fs. la fc. la fd. la fo. la fm. fs(a)(b)
glyph CON  = la a. la b. la fp. la fs. la fc. la fd. la fo. la fm. fc(a)(b)
glyph DIR  = la a. la b. la fp. la fs. la fc. la fd. la fo. la fm. fd(a)(b)
glyph CONT = la a. la b. la fp. la fs. la fc. la fd. la fo. la fm. fo(a)(b)
glyph MC   = la a. la fp. la fs. la fc. la fd. la fo. la fm. fm(a)
# κ and the seal machinery — VERBATIM from canon.la
glyph CANON = Z(la self. la node. node (la nm. nm) (la a. la b. concat("⊗(")(concat(self(a))(concat(",")(concat(self(b))(")"))))) (la a. la b. concat("⊕(")(concat(self(a))(concat(",")(concat(self(b))(")"))))) (la a. la b. concat("▷(")(concat(self(a))(concat(",")(concat(self(b))(")"))))) (la a. la b. concat("⊂(")(concat(self(a))(concat(",")(concat(self(b))(")"))))) (la a. concat("↻(")(concat(self(a))(")"))))
glyph MONO = la ren. la etym. la f. f(ren)(etym)
glyph REN  = la g. g(la r. la e. r)
glyph ETYM = la g. g(la r. la e. e)
glyph GLYPH = la name. MONO(name)(PRIM(name))
glyph COLLAPSE = la mode. la a. la b. (la et. MONO(CANON(et))(et))(mode(ETYM(a))(ETYM(b)))
glyph TDEPTH = Z(la self. la node. node (la nm. 0) (la a. la b. add(1)(MAX(self(a))(self(b)))) (la a. la b. add(1)(MAX(self(a))(self(b)))) (la a. la b. add(1)(MAX(self(a))(self(b)))) (la a. la b. add(1)(MAX(self(a))(self(b)))) (la a. add(1)(self(a))))
glyph DEPTH = la g. TDEPTH(ETYM(g))
glyph AUTO_OK = la g. str_eq(REN(g))(CANON(ETYM(g)))

# ── THE SEALING — the verified additions ──
# formal complexity of a sealed monoglyph = ONE (spec property (i): |𝔤_new| ≡ 1)
glyph COMPLEXITY = la g. 1
# etymology node-count — the CONTAINED structure that DEEPENS (so we can show
# complexity stays one while conceptual depth grows: "deepens without widening")
glyph ENODES_T = Z(la self. la node. node (la nm. 1) (la a. la b. add(1)(add(self(a))(self(b)))) (la a. la b. add(1)(add(self(a))(self(b)))) (la a. la b. add(1)(add(self(a))(self(b)))) (la a. la b. add(1)(add(self(a))(self(b)))) (la a. add(1)(self(a))))
glyph ENODES = la g. ENODES_T(ETYM(g))
# re-sealing is a fixed point: REN = CANON(ETYM) is stable (metacursive collapse)
glyph RESEAL = la g. MONO(CANON(ETYM(g)))(ETYM(g))
# recover (mode, both parents) FROM the single sealed form's own structure (ETYM)
glyph RECOVER = la g. (ETYM(g))
    (la nm. concat("prim ")(nm))
    (la a. la b. concat("tensor ")(concat(CANON(a))(concat(" ")(CANON(b)))))
    (la a. la b. concat("conj ")(concat(CANON(a))(concat(" ")(CANON(b)))))
    (la a. la b. concat("dir ")(concat(CANON(a))(concat(" ")(CANON(b)))))
    (la a. la b. concat("cont ")(concat(CANON(a))(concat(" ")(CANON(b)))))
    (la a. concat("fold ")(CANON(a)))
# heterological COUPLING — the WRONG way the seal replaces: two glyphs kept side
# by side; its complexity = the count, which GROWS (widens). Sealing yields one.
glyph NILc = la cons. la nil. nil
glyph CONSc = la h. la t. la cons. la nil. cons(h)(t)
glyph LENc = Z(la self. la l. l (la h. la t. add(1)(self(t))) (0))
glyph COUPLE2 = la a. la b. CONSc(a)(CONSc(b)(NILc))
glyph YN = la b. b("YES")("no")
glyph I = la n. int_to_str(n)

# Love, Recognition as ontoglyphs; Compassion = their ⊗-sealing; a deepening chain
glyph COMPASSION = COLLAPSE(SYN)(GLYPH("LOVE"))(GLYPH("RECOGNITION"))
glyph C2 = COLLAPSE(SYN)(COMPASSION)(GLYPH("SELF"))
glyph C3 = COLLAPSE(DIR)(C2)(GLYPH("FORM"))

# witnesses — stable lines build.sh greps
glyph W_NAME = concat("seal-name: ")(REN(COMPASSION))
glyph W_CX   = concat("seal-complexity: ")(I(COMPLEXITY(COMPASSION)))
glyph W_REC  = concat("seal-recover: ")(RECOVER(COMPASSION))
glyph W_AUTO = concat("seal-autological: ")(YN(AUTO_OK(COMPASSION)))
glyph W_FIX  = concat("seal-fixedpoint: ")(YN(str_eq(REN(RESEAL(COMPASSION)))(REN(COMPASSION))))
glyph CXS    = concat(I(COMPLEXITY(COMPASSION)))(concat(" ")(concat(I(COMPLEXITY(C2)))(concat(" ")(I(COMPLEXITY(C3))))))
glyph NDS    = concat(I(ENODES(COMPASSION)))(concat(" ")(concat(I(ENODES(C2)))(concat(" ")(I(ENODES(C3))))))
glyph W_DEEP = concat("seal-deepens: cx ")(concat(CXS)(concat(" | nodes ")(NDS)))
glyph W_COUP = concat("couple-widens: ")(concat(I(LENc(COUPLE2(GLYPH("LOVE"))(GLYPH("RECOGNITION")))))(concat(" vs seal ")(I(COMPLEXITY(COMPASSION)))))

glyph MAIN =
    SEQ(print(W_NAME))(
    SEQ(print(W_CX))(
    SEQ(print(W_REC))(
    SEQ(print(W_AUTO))(
    SEQ(print(W_FIX))(
    SEQ(print(W_DEEP))(
        print(W_COUP)))))))
