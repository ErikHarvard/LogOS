  CONS(E("DECOMP")("recover full etymology tree from one form (trusted)")(SRC_DECOMP)(DECOMP)(T2L(TC(la g. DAG(g("BEING;VOID;⊗0.1;⊗2.2")))("BEING;VOID;⊗0.1;⊗2.2"))(TC(la g. int_to_str(TSIZE(g("BEING;VOID;⊗0.1;⊗2.2"))))("7"))))(
