# ═══════════════════════════════════════════════════════════════════
#  bytecode.la — byte instructions for Lingua Adamica, and their parser
#
#  We already have two representations of a program:
#    • source text   — what you write; PARSE_PROGRAM reads it, SHOW_SRC
#                       writes it
#    • the AST        — the parsed tree the evaluator walks
#  This file adds a third: a flat **byte-instruction** stream, the kind
#  of compact linear encoding a VM would load. EMIT compiles an AST into
#  byte instructions; PARSE_BYTES — the parser for byte instructions —
#  decodes them back into an AST.
#
#  Instruction format (prefix / Polish notation, one opcode per node):
#    V <field>            — variable        (name)
#    S <field>            — string literal  (value)
#    L <field> <expr>     — lambda          (param, then body)
#    A <expr> <expr>      — application     (function, then argument)
#  A <field> is escaped content terminated by ';' :  ';' -> '\;' and
#  '\' -> '\\', so a field never contains an unescaped terminator. The
#  opcode fixes how many sub-expressions follow, so decoding is a plain
#  recursive descent — exactly like the text parser, over bytes.
#
#  Round trip:   text --PARSE_PROGRAM--> AST --EMIT--> bytes
#                     --PARSE_BYTES--> AST --SHOW_SRC--> text
#  and the two texts agree.
# ═══════════════════════════════════════════════════════════════════

# ── Foundations ─────────────────────────────────────────────────────

glyph TRUE  = la t. la f. t
glyph FALSE = la t. la f. f
glyph ID    = la x. x
glyph SEQ   = la a. la b. b

glyph Z  = la f. (la x. f(la v. x(x)(v)))(la x. f(la v. x(x)(v)))
glyph IF = la cond. la t. la f. cond(t)(f)("!")

glyph PAIR = la a. la b. la f. f(a)(b)
glyph FST  = la p. p(la a. la b. a)
glyph SND  = la p. p(la a. la b. b)

glyph NONE    = PAIR(FALSE)("")
glyph SOME    = la val. la rest. PAIR(TRUE)(PAIR(val)(rest))
glyph IS_SOME = la r. FST(r)
glyph R_VAL   = la r. FST(SND(r))
glyph R_REST  = la r. SND(SND(r))

glyph NIL      = PAIR(FALSE)("")
glyph CONS     = la h. la t. PAIR(TRUE)(PAIR(h)(t))
glyph IS_CONS  = la lst. FST(lst)
glyph LIST_HD  = la lst. FST(SND(lst))
glyph LIST_TL  = la lst. SND(SND(lst))

# ── AST constructors ────────────────────────────────────────────────
#  node(on_var)(on_lam)(on_app)(on_str)

glyph AST_VAR = la name. la v. la l. la a. la s. v(name)
glyph AST_LAM = la param. la body. la v. la l. la a. la s. l(param)(body)
glyph AST_APP = la func. la arg. la v. la l. la a. la s. a(func)(arg)
glyph AST_STR = la val. la v. la l. la a. la s. s(val)

# ── Lexer ───────────────────────────────────────────────────────────

glyph IS_SPACE = la c. IF(str_eq(c)(" "))(la _. TRUE)(la _. IF(str_eq(c)("\n"))(la _. TRUE)(la _. IF(str_eq(c)("\t"))(la _. TRUE)(la _. FALSE)))

glyph IS_SPECIAL = la c. IF(str_eq(c)("("))(la _. TRUE)(la _. IF(str_eq(c)(")"))(la _. TRUE)(la _. IF(str_eq(c)("."))(la _. TRUE)(la _. IF(str_eq(c)("="))(la _. TRUE)(la _. FALSE))))

glyph IS_QUOTE_OR_HASH = la c. IF(str_eq(c)("\""))(la _. TRUE)(la _. IF(str_eq(c)("#"))(la _. TRUE)(la _. FALSE))

glyph IS_IDENT_CHAR = la c. IF(str_eq(c)(""))(la _. FALSE)(la _. IF(IS_SPACE(c))(la _. FALSE)(la _. IF(IS_SPECIAL(c))(la _. FALSE)(la _. IF(IS_QUOTE_OR_HASH(c))(la _. FALSE)(la _. TRUE))))

glyph SKIP_LINE = Z(la self. la s. IF(str_eq(s)(""))(la _. s)(la _. IF(str_eq(str_head(s))("\n"))(la _. str_tail(s))(la _. self(str_tail(s)))))

glyph SKIP_SPACES = Z(la self. la s. IF(str_eq(s)(""))(la _. s)(la _. IF(IS_SPACE(str_head(s)))(la _. self(str_tail(s)))(la _. IF(str_eq(str_head(s))("#"))(la _. self(SKIP_LINE(s)))(la _. s))))

glyph READ_IDENT = Z(la self. la acc. la s. IF(IS_IDENT_CHAR(str_head(s)))(la _. self(concat(acc)(str_head(s)))(str_tail(s)))(la _. PAIR(acc)(s)))
# str_eq only (no int builtins) so the lexer is uniform across all engines.
glyph IS_DIGIT = la c. IF(str_eq(c)("0"))(la _. TRUE)(la _. IF(str_eq(c)("1"))(la _. TRUE)(la _. IF(str_eq(c)("2"))(la _. TRUE)(la _. IF(str_eq(c)("3"))(la _. TRUE)(la _. IF(str_eq(c)("4"))(la _. TRUE)(la _. IF(str_eq(c)("5"))(la _. TRUE)(la _. IF(str_eq(c)("6"))(la _. TRUE)(la _. IF(str_eq(c)("7"))(la _. TRUE)(la _. IF(str_eq(c)("8"))(la _. TRUE)(la _. IF(str_eq(c)("9"))(la _. TRUE)(la _. FALSE))))))))))
glyph READ_INT = Z(la self. la acc. la s. IF(IS_DIGIT(str_head(s)))(la _. self(concat(acc)(str_head(s)))(str_tail(s)))(la _. PAIR(acc)(s)))

glyph UNESCAPE = la c. IF(str_eq(c)("n"))(la _. "\n")(la _. IF(str_eq(c)("t"))(la _. "\t")(la _. c))

glyph READ_STRING = Z(la self. la acc. la s. IF(str_eq(s)(""))(la _. PAIR(acc)(s))(la _. IF(str_eq(str_head(s))("\""))(la _. PAIR(acc)(str_tail(s)))(la _. IF(str_eq(str_head(s))("\\"))(la _. self(concat(acc)(UNESCAPE(str_head(str_tail(s)))))(str_tail(str_tail(s))))(la _. self(concat(acc)(str_head(s)))(str_tail(s))))))

glyph TOK_TYPE = la tok. FST(tok)
glyph TOK_VAL  = la tok. SND(tok)
glyph MKTOK    = la ty. la val. PAIR(ty)(val)

glyph LEX_ONE = la s. IF(str_eq(s)(""))(la _. PAIR(MKTOK("eof")(""))(s))(la _. IF(str_eq(str_head(s))("("))(la _. PAIR(MKTOK("lp")("("))(str_tail(s)))(la _. IF(str_eq(str_head(s))(")"))(la _. PAIR(MKTOK("rp")(")"))(str_tail(s)))(la _. IF(str_eq(str_head(s))("."))(la _. PAIR(MKTOK("dot")("."))(str_tail(s)))(la _. IF(str_eq(str_head(s))("="))(la _. PAIR(MKTOK("eq")("="))(str_tail(s)))(la _. IF(str_eq(str_head(s))("\""))(la _. (la r. PAIR(MKTOK("str")(FST(r)))(SND(r)))(READ_STRING("")(str_tail(s))))(la _. IF(IS_DIGIT(str_head(s)))(la _. (la r. PAIR(MKTOK("int")(FST(r)))(SND(r)))(READ_INT("")(s)))(la _. IF(IS_IDENT_CHAR(str_head(s)))(la _. (la r. (la name. (la rest. IF(str_eq(name)("glyph"))(la _. PAIR(MKTOK("glyph")("glyph"))(rest))(la _. IF(str_eq(name)("la"))(la _. PAIR(MKTOK("la")("la"))(rest))(la _. PAIR(MKTOK("ident")(name))(rest))))(SND(r)))(FST(r)))(READ_IDENT("")(s)))(la _. PAIR(MKTOK("eof")(""))(s)))))))))

glyph NEXT_TOKEN = la s. LEX_ONE(SKIP_SPACES(s))

# ── Parser (text -> AST) ────────────────────────────────────────────

glyph PARSE_PRIMARY = la s. (la tr. (la tok. (la rest. IF(str_eq(TOK_TYPE(tok))("ident"))(la _. SOME(AST_VAR(TOK_VAL(tok)))(rest))(la _. IF(str_eq(TOK_TYPE(tok))("str"))(la _. SOME(AST_STR(TOK_VAL(tok)))(rest))(la _. IF(str_eq(TOK_TYPE(tok))("int"))(la _. SOME(AST_APP(AST_VAR("str_to_int"))(AST_STR(TOK_VAL(tok))))(rest))(la _. IF(str_eq(TOK_TYPE(tok))("lp"))(la _. (la inner. IF(IS_SOME(inner))(la _. (la tr2. (la tok2. (la rest2. IF(str_eq(TOK_TYPE(tok2))("rp"))(la _. SOME(R_VAL(inner))(rest2))(la _. NONE))(SND(tr2)))(FST(tr2)))(NEXT_TOKEN(R_REST(inner))))(la _. NONE))(PARSE_EXPR(rest)))(la _. NONE)))))(SND(tr)))(FST(tr)))(NEXT_TOKEN(s))

glyph PARSE_APP_TAIL = Z(la self. la acc. la s. (la tr. (la tok. (la rest. IF(str_eq(TOK_TYPE(tok))("lp"))(la _. (la arg. IF(IS_SOME(arg))(la _. (la tr2. (la tok2. (la rest2. IF(str_eq(TOK_TYPE(tok2))("rp"))(la _. self(AST_APP(acc)(R_VAL(arg)))(rest2))(la _. NONE))(SND(tr2)))(FST(tr2)))(NEXT_TOKEN(R_REST(arg))))(la _. NONE))(PARSE_EXPR(rest)))(la _. SOME(acc)(s)))(SND(tr)))(FST(tr)))(NEXT_TOKEN(s)))

glyph PARSE_APP = la s. (la base. IF(IS_SOME(base))(la _. PARSE_APP_TAIL(R_VAL(base))(R_REST(base)))(la _. NONE))(PARSE_PRIMARY(s))

glyph PARSE_EXPR = Z(la self_expr. la s. (la tr. (la tok. (la rest. IF(str_eq(TOK_TYPE(tok))("la"))(la _. (la tr2. (la tok2. (la rest2. IF(str_eq(TOK_TYPE(tok2))("ident"))(la _. (la tr3. (la tok3. (la rest3. IF(str_eq(TOK_TYPE(tok3))("dot"))(la _. (la body. IF(IS_SOME(body))(la _. SOME(AST_LAM(TOK_VAL(tok2))(R_VAL(body)))(R_REST(body)))(la _. NONE))(self_expr(rest3)))(la _. NONE))(SND(tr3)))(FST(tr3)))(NEXT_TOKEN(rest2)))(la _. NONE))(SND(tr2)))(FST(tr2)))(NEXT_TOKEN(rest)))(la _. PARSE_APP(s)))(SND(tr)))(FST(tr)))(NEXT_TOKEN(s)))

glyph PARSE_GLYPH = la s. (la tr. (la tok. (la rest. IF(str_eq(TOK_TYPE(tok))("glyph"))(la _. (la tr2. (la tok2. (la rest2. IF(str_eq(TOK_TYPE(tok2))("ident"))(la _. (la tr3. (la tok3. (la rest3. IF(str_eq(TOK_TYPE(tok3))("eq"))(la _. (la body. IF(IS_SOME(body))(la _. SOME(PAIR(TOK_VAL(tok2))(R_VAL(body)))(R_REST(body)))(la _. NONE))(PARSE_EXPR(rest3)))(la _. NONE))(SND(tr3)))(FST(tr3)))(NEXT_TOKEN(rest2)))(la _. NONE))(SND(tr2)))(FST(tr2)))(NEXT_TOKEN(rest)))(la _. NONE))(SND(tr)))(FST(tr)))(NEXT_TOKEN(s))

glyph PARSE_PROGRAM = Z(la self. la s. (la s2. (la g. IF(IS_SOME(g))(la _. (la rest_parsed. CONS(R_VAL(g))(rest_parsed))(self(R_REST(g))))(la _. NIL))(PARSE_GLYPH(s2)))(SKIP_SPACES(s)))

# ── Unparser (AST -> text) ──────────────────────────────────────────

glyph ESC_CHAR = la c.
    IF(str_eq(c)("\\"))(la _. "\\\\")(la _.
    IF(str_eq(c)("\""))(la _. "\\\"")(la _.
    IF(str_eq(c)("\n"))(la _. "\\n")(la _.
    IF(str_eq(c)("\t"))(la _. "\\t")(la _.
    c))))

glyph ESCAPE = Z(la self. la s.
    IF(str_eq(s)(""))(la _. "")(la _.
        concat(ESC_CHAR(str_head(s)))(self(str_tail(s)))))

glyph SHOW_FUN_POS = la rec. la f.
    f
        (la name. rec(f))
        (la p. la b. concat("(")(concat(rec(f))(")")))
        (la g. la a. rec(f))
        (la val. rec(f))

glyph SHOW_SRC = Z(la self. la node.
    node
        (la name. name)
        (la p. la b. concat("la ")(concat(p)(concat(". ")(self(b)))))
        (la f. la arg. concat(SHOW_FUN_POS(self)(f))(concat("(")(concat(self(arg))(")"))))
        (la val. concat("\"")(concat(ESCAPE(val))("\"")))
)

glyph SHOW_PROGRAM = Z(la self. la gl.
    IF(IS_CONS(gl))(la _.
        (la entry.
            concat("glyph ")(concat(FST(entry))(concat(" = ")(concat(SHOW_SRC(SND(entry)))(concat("\n")(self(LIST_TL(gl)))))))
        )(LIST_HD(gl))
    )(la _. ""))

# ═══════════════════════════════════════════════════════════════════
#  Byte instructions
# ═══════════════════════════════════════════════════════════════════

# ── Field encoding: escaped content terminated by ';' ───────────────
# In source, "\\;" is the two-char value \ ; and "\\\\" is the two-char
# value \ \ — so ESC_FIELD_CHAR turns one byte into its escaped form.

glyph ESC_FIELD_CHAR = la c.
    IF(str_eq(c)(";"))(la _. "\\;")(la _.
    IF(str_eq(c)("\\"))(la _. "\\\\")(la _.
    c))

glyph ESCAPE_FIELD = Z(la self. la s.
    IF(str_eq(s)(""))(la _. "")(la _.
        concat(ESC_FIELD_CHAR(str_head(s)))(self(str_tail(s)))))

# ENCODE_FIELD(s) — escaped content plus the ';' terminator.
glyph ENCODE_FIELD = la s. concat(ESCAPE_FIELD(s))(";")

# READ_FIELD(stream) -> PAIR(content)(rest) : read up to an unescaped
# ';', unescaping '\X' to X along the way and consuming the terminator.
glyph READ_FIELD = Z(la self. la acc. la s.
    IF(str_eq(s)(""))(la _. PAIR(acc)(s))(la _.
    IF(str_eq(str_head(s))("\\"))(la _.
        self(concat(acc)(str_head(str_tail(s))))(str_tail(str_tail(s)))
    )(la _.
    IF(str_eq(str_head(s))(";"))(la _.
        PAIR(acc)(str_tail(s))
    )(la _.
        self(concat(acc)(str_head(s)))(str_tail(s))
    ))))

# ── EMIT: AST -> byte instructions ──────────────────────────────────

glyph EMIT = Z(la self. la node.
    node
        (la name. concat("V")(ENCODE_FIELD(name)))
        (la p. la b. concat("L")(concat(ENCODE_FIELD(p))(self(b))))
        (la f. la a. concat("A")(concat(self(f))(self(a))))
        (la val. concat("S")(ENCODE_FIELD(val)))
)

# ── PARSE_BYTES: the parser for byte instructions ───────────────────
# byte stream -> PAIR(ast)(rest_of_stream).  Recursive descent on the
# leading opcode, exactly mirroring the text parser one level lower.

glyph PARSE_BYTES = Z(la self. la s.
    (la op. (la rest0.
        IF(str_eq(op)("V"))(la _.
            (la fr. PAIR(AST_VAR(FST(fr)))(SND(fr)))(READ_FIELD("")(rest0))
        )(la _.
        IF(str_eq(op)("S"))(la _.
            (la fr. PAIR(AST_STR(FST(fr)))(SND(fr)))(READ_FIELD("")(rest0))
        )(la _.
        IF(str_eq(op)("L"))(la _.
            (la fr. (la body_r.
                PAIR(AST_LAM(FST(fr))(FST(body_r)))(SND(body_r))
            )(self(SND(fr))))(READ_FIELD("")(rest0))
        )(la _.
        IF(str_eq(op)("A"))(la _.
            (la fn_r. (la arg_r.
                PAIR(AST_APP(FST(fn_r))(FST(arg_r)))(SND(arg_r))
            )(self(SND(fn_r))))(self(rest0))
        )(la _.
            PAIR(AST_STR("?bad-opcode"))(rest0)
        ))))
    )(str_tail(s)))(str_head(s)))

# DECODE(stream) — parse one expression and return its AST.
glyph DECODE = la s. FST(PARSE_BYTES(s))

# ROUNDTRIP_AST(ast) = DECODE(EMIT(ast)) — through bytes and back.
glyph ROUNDTRIP_AST = la ast. DECODE(EMIT(ast))

# MAP_GLYPHS(f)(gl) — apply f to every glyph's AST in a table.
glyph MAP_GLYPHS = la f. Z(la self. la gl.
    IF(IS_CONS(gl))(la _.
        (la entry. CONS(PAIR(FST(entry))(f(SND(entry))))(self(LIST_TL(gl))))(LIST_HD(gl))
    )(la _. NIL))

# ═══════════════════════════════════════════════════════════════════
#  A virtual machine: execute byte instructions DIRECTLY
#
#  RUN_BYTES walks the byte stream and produces a value, without ever
#  calling PARSE_BYTES or rebuilding an AST. It is the closure-based
#  evaluator of eval.la, lowered one level: where that walks AST nodes,
#  this walks bytes; where a closure there captured a body AST, here it
#  captures the body's byte-slice and re-enters RUN_BYTES to run it.
# ═══════════════════════════════════════════════════════════════════

glyph LIST_FIND = Z(la self. la name. la lst.
    IF(IS_CONS(lst))(la _.
        (la entry. IF(str_eq(name)(FST(entry)))(la _. SOME(SND(entry))(""))(la _. self(name)(LIST_TL(lst))))(LIST_HD(lst))
    )(la _. NONE))

# Values: val(on_str)(on_clo)(on_bi)(on_pa).  Same shape as eval.la's,
# but VAL_CLO's body is a byte stream, not an AST.
glyph VAL_STR = la s.    la os. la oc. la ob. la op. la oi. os(s)
glyph VAL_CLO = la p. la body. la env. la os. la oc. la ob. la op. la oi. oc(p)(body)(env)
glyph VAL_BI  = la name. la os. la oc. la ob. la op. la oi. ob(name)
glyph VAL_PA  = la name. la v.  la os. la oc. la ob. la op. la oi. op(name)(v)
glyph VAL_INT = la n.    la os. la oc. la ob. la op. la oi. oi(n)

glyph UNWRAP_STR = la val. val (la s. s) (la p. la b. la e. "") (la n. "") (la n. la v. "") (la n. int_to_str(n))
glyph UNWRAP_INT = la val. val (la s. 0) (la p. la b. la e. 0) (la n. 0) (la n. la v. 0) (la n. n)

glyph IS_BI_NAME = la name.
    IF(str_eq(name)("print"))(la _. TRUE)(la _.
    IF(str_eq(name)("copy_self"))(la _. TRUE)(la _.
    IF(str_eq(name)("read_file"))(la _. TRUE)(la _.
    IF(str_eq(name)("write_file"))(la _. TRUE)(la _.
    IF(str_eq(name)("concat"))(la _. TRUE)(la _.
    IF(str_eq(name)("str_head"))(la _. TRUE)(la _.
    IF(str_eq(name)("str_tail"))(la _. TRUE)(la _.
    IF(str_eq(name)("str_eq"))(la _. TRUE)(la _.
    IS_BI_NAME_INT(name)))))))))

# str_eq yields Church booleans; in the VM those must be closures whose
# bodies are BYTE instructions, so applying them runs under RUN_BYTES.
glyph BYTE_TRUE  = VAL_CLO("t")(EMIT(AST_LAM("f")(AST_VAR("t"))))(NIL)
glyph BYTE_FALSE = VAL_CLO("t")(EMIT(AST_LAM("f")(AST_VAR("f"))))(NIL)

# ── Native integers, factored into helpers so the existing dispatch chains
# keep their exact shape (each just falls through to one of these). VAL_INT
# carries the host integer; a literal n is parsed as str_to_int("n"). The
# bool result (lt/int_eq) is passed in as t/f so the same arithmetic serves
# both the byte VM (BYTE_TRUE/FALSE) and the stack machine (SM_TRUE/FALSE).
glyph IS_BI_NAME_INT = la name.
    IF(str_eq(name)("add"))(la _. TRUE)(la _.
    IF(str_eq(name)("sub"))(la _. TRUE)(la _.
    IF(str_eq(name)("mul"))(la _. TRUE)(la _.
    IF(str_eq(name)("div"))(la _. TRUE)(la _.
    IF(str_eq(name)("mod"))(la _. TRUE)(la _.
    IF(str_eq(name)("lt"))(la _. TRUE)(la _.
    IF(str_eq(name)("int_eq"))(la _. TRUE)(la _.
    IF(str_eq(name)("int_to_str"))(la _. TRUE)(la _.
    IF(str_eq(name)("str_to_int"))(la _. TRUE)(la _.
    FALSE)))))))))

glyph APPLY_BI_INT = la name. la val.
    IF(str_eq(name)("int_to_str"))(la _. VAL_STR(int_to_str(UNWRAP_INT(val))))(la _.
    IF(str_eq(name)("str_to_int"))(la _. VAL_INT(str_to_int(UNWRAP_STR(val))))(la _.
    IF(str_eq(name)("add"))(la _. VAL_PA("add")(val))(la _.
    IF(str_eq(name)("sub"))(la _. VAL_PA("sub")(val))(la _.
    IF(str_eq(name)("mul"))(la _. VAL_PA("mul")(val))(la _.
    IF(str_eq(name)("div"))(la _. VAL_PA("div")(val))(la _.
    IF(str_eq(name)("mod"))(la _. VAL_PA("mod")(val))(la _.
    IF(str_eq(name)("lt"))(la _. VAL_PA("lt")(val))(la _.
    IF(str_eq(name)("int_eq"))(la _. VAL_PA("int_eq")(val))(la _.
    VAL_STR(concat("ERROR: unknown builtin ")(name)))))))))))

glyph APPLY_BI2_INT = la t. la f. la name. la v1. la v2.
    IF(str_eq(name)("add"))(la _. VAL_INT(add(UNWRAP_INT(v1))(UNWRAP_INT(v2))))(la _.
    IF(str_eq(name)("sub"))(la _. VAL_INT(sub(UNWRAP_INT(v1))(UNWRAP_INT(v2))))(la _.
    IF(str_eq(name)("mul"))(la _. VAL_INT(mul(UNWRAP_INT(v1))(UNWRAP_INT(v2))))(la _.
    IF(str_eq(name)("div"))(la _. VAL_INT(div(UNWRAP_INT(v1))(UNWRAP_INT(v2))))(la _.
    IF(str_eq(name)("mod"))(la _. VAL_INT(mod(UNWRAP_INT(v1))(UNWRAP_INT(v2))))(la _.
    IF(str_eq(name)("lt"))(la _. IF(lt(UNWRAP_INT(v1))(UNWRAP_INT(v2)))(la _. t)(la _. f))(la _.
    IF(str_eq(name)("int_eq"))(la _. IF(int_eq(UNWRAP_INT(v1))(UNWRAP_INT(v2)))(la _. t)(la _. f))(la _.
    VAL_STR(concat("ERROR: unknown builtin2 ")(name)))))))))

# First-argument builtin dispatch (effects pass through to the host).
glyph APPLY_BI = la name. la val.
    IF(str_eq(name)("print"))(la _. (la s. (la _. val)(print(s)))(UNWRAP_STR(val)))(la _.
    IF(str_eq(name)("copy_self"))(la _. (la path. VAL_STR(path))(copy_self(UNWRAP_STR(val))))(la _.
    IF(str_eq(name)("read_file"))(la _. VAL_STR(read_file(UNWRAP_STR(val))))(la _.
    IF(str_eq(name)("write_file"))(la _. VAL_PA("write_file")(val))(la _.
    IF(str_eq(name)("concat"))(la _. VAL_PA("concat")(val))(la _.
    IF(str_eq(name)("str_head"))(la _. VAL_STR(str_head(UNWRAP_STR(val))))(la _.
    IF(str_eq(name)("str_tail"))(la _. VAL_STR(str_tail(UNWRAP_STR(val))))(la _.
    IF(str_eq(name)("str_eq"))(la _. VAL_PA("str_eq")(val))(la _.
    APPLY_BI_INT(name)(val)))))))))

# Second-argument builtin dispatch.
glyph APPLY_BI2 = la name. la v1. la v2.
    IF(str_eq(name)("write_file"))(la _. (la _. v2)(write_file(UNWRAP_STR(v1))(UNWRAP_STR(v2))))(la _.
    IF(str_eq(name)("concat"))(la _. VAL_STR(concat(UNWRAP_STR(v1))(UNWRAP_STR(v2))))(la _.
    IF(str_eq(name)("str_eq"))(la _. IF(str_eq(UNWRAP_STR(v1))(UNWRAP_STR(v2)))(la _. BYTE_TRUE)(la _. BYTE_FALSE))(la _.
    APPLY_BI2_INT(BYTE_TRUE)(BYTE_FALSE)(name)(v1)(v2))))

# SKIP_FIELD / SKIP_BYTES — advance past one field / one expression
# without evaluating, so a lambda can find where its body ends.
glyph SKIP_FIELD = Z(la self. la s.
    IF(str_eq(s)(""))(la _. s)(la _.
    IF(str_eq(str_head(s))("\\"))(la _. self(str_tail(str_tail(s))))(la _.
    IF(str_eq(str_head(s))(";"))(la _. str_tail(s))(la _.
    self(str_tail(s))))))

glyph SKIP_BYTES = Z(la self. la s.
    (la op. (la rest0.
        IF(str_eq(op)("V"))(la _. SKIP_FIELD(rest0))(la _.
        IF(str_eq(op)("S"))(la _. SKIP_FIELD(rest0))(la _.
        IF(str_eq(op)("L"))(la _. self(SKIP_FIELD(rest0)))(la _.
        IF(str_eq(op)("A"))(la _. self(self(rest0)))(la _.
        rest0))))
    )(str_tail(s)))(str_head(s)))

# RUN_BYTES(stream)(env)(gl) -> PAIR(value)(rest_of_stream).
#   env : list of PAIR(name)(value)      — local bindings
#   gl  : list of PAIR(name)(body_bytes) — the compiled glyph table
glyph RUN_BYTES = Z(la self. la s. la env. la gl.
    (la op. (la rest0.
        # ── V: variable — env, then glyph table, then builtin ──
        IF(str_eq(op)("V"))(la _.
            (la fr. (la name. (la rest1.
                (la local.
                    IF(IS_SOME(local))(la _. PAIR(R_VAL(local))(rest1))(la _.
                    (la found.
                        IF(IS_SOME(found))(la _. PAIR(FST(self(R_VAL(found))(NIL)(gl)))(rest1))(la _.
                        IF(IS_BI_NAME(name))(la _. PAIR(VAL_BI(name))(rest1))(la _.
                        error(concat("vm: unbound variable: ")(name))))
                    )(LIST_FIND(name)(gl)))
                )(LIST_FIND(name)(env))
            )(SND(fr)))(FST(fr)))(READ_FIELD("")(rest0))
        )(la _.
        # ── S: string literal ──
        IF(str_eq(op)("S"))(la _.
            (la fr. PAIR(VAL_STR(FST(fr)))(SND(fr)))(READ_FIELD("")(rest0))
        )(la _.
        # ── L: lambda — capture param, body byte-slice, and env ──
        IF(str_eq(op)("L"))(la _.
            (la fr. (la param. (la body.
                PAIR(VAL_CLO(param)(body)(env))(SKIP_BYTES(body))
            )(SND(fr)))(FST(fr)))(READ_FIELD("")(rest0))
        )(la _.
        # ── A: application — run func, run arg, dispatch on the value ──
        IF(str_eq(op)("A"))(la _.
            (la fn_r. (la arg_r.
                (la fval. (la aval.
                    PAIR(
                        fval
                            (la str. VAL_STR(concat("vm: cannot apply string: ")(str)))
                            (la p. la b. la e. FST(self(b)(CONS(PAIR(p)(aval))(e))(gl)))
                            (la bn. APPLY_BI(bn)(aval))
                            (la pn. la pv. APPLY_BI2(pn)(pv)(aval))
                            (la n. VAL_STR("vm: cannot apply integer"))
                    )(SND(arg_r))
                )(FST(arg_r)))(FST(fn_r))
            )(self(SND(fn_r))(env)(gl)))(self(rest0)(env)(gl))
        )(la _.
            PAIR(VAL_STR("vm: bad opcode"))(rest0)
        ))))
    )(str_tail(s)))(str_head(s)))

# COMPILE(gl_ast) — compile a parsed program (name->AST) into a byte
# glyph table (name->bytes). EXEC runs MAIN's bytes against it.
glyph COMPILE = la gl. MAP_GLYPHS(EMIT)(gl)
glyph EXEC    = la bytes. la glb. FST(RUN_BYTES(bytes)(NIL)(glb))
glyph RUN_BYTES_PROGRAM = la gl_ast. (la glb. EXEC(R_VAL(LIST_FIND("MAIN")(glb)))(glb))(COMPILE(gl_ast))

# ═══════════════════════════════════════════════════════════════════
#  A real stack machine (S, E, C, D)
#
#  RUN_BYTES walks the tree shape with host recursion. The stack machine
#  does not: it compiles each expression to a FLAT, postfix instruction
#  list and runs an explicit state transition — operand Stack, local
#  Environment, Control (instructions left to do), Dump (saved C/E return
#  frames). The only recursion is the trampoline driving STEP to STEP;
#  control flow lives entirely on the explicit stacks.
#
#  Instructions:
#    PUSHS s        — push the string value s
#    PUSHV name     — push the value of a variable (env, glyph, builtin)
#    CLOSE p code   — push a closure capturing p, the body code, and env
#    APPLY          — pop arg, pop fn, apply (enter body / run builtin)
#
#  Compilation:
#    VAR n      -> [PUSHV n]
#    STR s      -> [PUSHS s]
#    LAM p b    -> [CLOSE p <code b>]
#    APP f x    -> <code f> ++ <code x> ++ [APPLY]
# ═══════════════════════════════════════════════════════════════════

glyph APPEND = Z(la self. la xs. la ys.
    IF(IS_CONS(xs))(la _. CONS(LIST_HD(xs))(self(LIST_TL(xs))(ys)))(la _. ys))

# Instructions: instr(on_pushs)(on_pushv)(on_close)(on_apply)
# Each handler is a lambda, so eager evaluation only runs the branch the
# instruction selects. APPLY carries no data, so it is forced with a
# dummy argument (the handler is a thunk `la _. ...`).
glyph I_PUSHS = la s.            la ps. la pv. la cl. la ap. ps(s)
glyph I_PUSHV = la name.         la ps. la pv. la cl. la ap. pv(name)
glyph I_CLOSE = la p. la code.   la ps. la pv. la cl. la ap. cl(p)(code)
glyph I_APPLY =                  la ps. la pv. la cl. la ap. ap(NIL)

# COMPILE_EXPR(ast) — linearise an AST into a postfix instruction list.
glyph COMPILE_EXPR = Z(la self. la node.
    node
        (la name. CONS(I_PUSHV(name))(NIL))
        (la p. la b. CONS(I_CLOSE(p)(self(b)))(NIL))
        (la f. la a. APPEND(self(f))(APPEND(self(a))(CONS(I_APPLY)(NIL))))
        (la val. CONS(I_PUSHS(val))(NIL))
)

# Church booleans for the machine: closures whose bodies are PRE-COMPILED
# instruction lists, written out as literals. These are exactly what
# COMPILE_EXPR(la f. t) and COMPILE_EXPR(la f. f) produce — [CLOSE f [PUSHV t]]
# and [CLOSE f [PUSHV f]] — but hoisted to constants so that COMPILE_EXPR is
# never reachable from RUN_SM: generation does not happen at recognition time.
glyph SM_TRUE_CODE  = CONS(I_CLOSE("f")(CONS(I_PUSHV("t"))(NIL)))(NIL)
glyph SM_FALSE_CODE = CONS(I_CLOSE("f")(CONS(I_PUSHV("f"))(NIL)))(NIL)
glyph SM_TRUE  = VAL_CLO("t")(SM_TRUE_CODE)(NIL)
glyph SM_FALSE = VAL_CLO("t")(SM_FALSE_CODE)(NIL)

# Second-argument builtin dispatch, str_eq yielding machine booleans.
glyph APPLY_BI2_SM = la name. la v1. la v2.
    IF(str_eq(name)("write_file"))(la _. (la _. v2)(write_file(UNWRAP_STR(v1))(UNWRAP_STR(v2))))(la _.
    IF(str_eq(name)("concat"))(la _. VAL_STR(concat(UNWRAP_STR(v1))(UNWRAP_STR(v2))))(la _.
    IF(str_eq(name)("str_eq"))(la _. IF(str_eq(UNWRAP_STR(v1))(UNWRAP_STR(v2)))(la _. SM_TRUE)(la _. SM_FALSE))(la _.
    APPLY_BI2_INT(SM_TRUE)(SM_FALSE)(name)(v1)(v2))))

# RUN_SM(gl0)(code0) — execute a compiled instruction list. The state is
# (S, E, C, D); STEP transitions it; the trampoline iterates to a halt
# (C and D both empty), whereupon the result is the top of the stack.
glyph RUN_SM = la gl0. la code0.
    (Z(la self. la S. la E. la C. la D.
        IF(IS_CONS(C))(la _.
            (la instr. (la C1.
                instr
                    (la str. self(CONS(VAL_STR(str))(S))(E)(C1)(D))
                    (la name.
                        (la local. IF(IS_SOME(local))(la _.
                            self(CONS(R_VAL(local))(S))(E)(C1)(D)
                        )(la _.
                            (la found. IF(IS_SOME(found))(la _.
                                self(S)(NIL)(R_VAL(found))(CONS(PAIR(C1)(E))(D))
                            )(la _. IF(IS_BI_NAME(name))(la _.
                                self(CONS(VAL_BI(name))(S))(E)(C1)(D)
                            )(la _.
                                error(concat("sm: unbound variable: ")(name))
                            )))(LIST_FIND(name)(gl0)))
                        )(LIST_FIND(name)(E)))
                    (la p. la body. self(CONS(VAL_CLO(p)(body)(E))(S))(E)(C1)(D))
                    (la _. (la arg. (la fn. (la S2.
                        fn
                            (la str. self(CONS(VAL_STR(concat("sm: cannot apply string: ")(str)))(S2))(E)(C1)(D))
                            (la p. la body. la e. self(S2)(CONS(PAIR(p)(arg))(e))(body)(CONS(PAIR(C1)(E))(D)))
                            (la bn. self(CONS(APPLY_BI(bn)(arg))(S2))(E)(C1)(D))
                            (la pn. la pv. self(CONS(APPLY_BI2_SM(pn)(pv)(arg))(S2))(E)(C1)(D))
                            (la n. self(CONS(VAL_STR("sm: cannot apply integer"))(S2))(E)(C1)(D))
                    )(LIST_TL(LIST_TL(S))))(LIST_HD(LIST_TL(S))))(LIST_HD(S)))
            )(LIST_TL(C)))(LIST_HD(C))
        )(la _.
            IF(IS_CONS(D))(la _.
                (la frame. self(S)(SND(frame))(FST(frame))(LIST_TL(D)))(LIST_HD(D))
            )(la _.
                LIST_HD(S)
            )
        )
    ))(NIL)(NIL)(code0)(NIL)

# COMPILE_PROGRAM — compile a parsed program (name->AST) to name->code.
glyph COMPILE_PROGRAM = la gl. MAP_GLYPHS(COMPILE_EXPR)(gl)
glyph RUN_SM_PROGRAM = la gl_ast. (la glc. RUN_SM(glc)(R_VAL(LIST_FIND("MAIN")(glc))))(COMPILE_PROGRAM(gl_ast))

# ── Tests ───────────────────────────────────────────────────────────

# A small AST built by hand, exercising every node kind, nesting, and a
# string literal that itself contains the field terminator ';' and a
# backslash — so the field escaping is genuinely tested.
glyph TEST_AST = AST_LAM("x")(AST_APP(AST_APP(AST_VAR("f"))(AST_VAR("x")))(AST_STR("a;b\\c")))

# A program exercised by the VM directly: a glyph reference (K), a
# curried builtin (concat), and a str_eq whose Church-boolean result is
# applied to select a branch — all run from bytes, no AST rebuilt.
glyph VM_SRC = "glyph K = la x. la y. x\nglyph MAIN = concat(str_eq(\"p\")(\"p\")(\"yes \")(\"no \"))(K(\"kept\")(\"dropped\"))\n"

# Exercises BOTH machine booleans: str_eq match -> SM_TRUE picks the first
# branch ("T"), str_eq mismatch -> SM_FALSE picks the second ("F"); concat
# -> "TF". Guards the precompiled SM_TRUE_CODE / SM_FALSE_CODE constants.
glyph BOOL_SRC = "glyph MAIN = concat(str_eq(\"a\")(\"a\")(\"T\")(\"-\"))(str_eq(\"a\")(\"b\")(\"-\")(\"F\"))\n"

glyph MAIN = SEQ(SEQ(SEQ(SEQ(SEQ(SEQ(SEQ(
    # Show the byte instructions for the hand-built AST.
    SEQ(print("--- byte instructions for  la x. f(x)(\"a;b\\c\") ---"))(
    print(EMIT(TEST_AST)))
)(
    # Decode them back and unparse — should match the original source.
    SEQ(print("--- decoded and unparsed ---"))(
    print(SHOW_SRC(DECODE(EMIT(TEST_AST)))))
))(
    # Single-expression round trip check.
    SEQ(print("--- expression round trip ---"))(
    print(str_eq(SHOW_SRC(TEST_AST))(SHOW_SRC(ROUNDTRIP_AST(TEST_AST)))("bytes round-trip: stable")("bytes round-trip: DIVERGED")))
))(
    # Whole-program round trip: parse kernel.la to ASTs, send every glyph
    # through bytes and back, and confirm the reconstructed source agrees.
    SEQ(print("--- kernel.la through byte instructions ---"))(
    (la gl.
        print(str_eq(SHOW_PROGRAM(gl))(SHOW_PROGRAM(MAP_GLYPHS(ROUNDTRIP_AST)(gl)))("kernel round-trip: stable")("kernel round-trip: DIVERGED"))
    )(PARSE_PROGRAM(read_file("kernel.la"))))
))(
    # Execute byte instructions DIRECTLY — RUN_BYTES, no PARSE_BYTES.
    # First a literal hand-written byte stream (no parser, no EMIT): the
    # instructions for  concat("byte ")("vm")  run straight to a value.
    SEQ(print("--- executing byte instructions directly ---"))(
    SEQ(print(UNWRAP_STR(EXEC("AAVconcat;Sbyte ;Svm;")(NIL))))(
    print(UNWRAP_STR(RUN_BYTES_PROGRAM(PARSE_PROGRAM(VM_SRC))))))
))(
    # The kernel, executed straight from its byte instructions: it speaks
    # the Word and replicates, with no AST ever reconstructed.
    SEQ(print("--- executing kernel.la from bytes (speaks + replicates) ---"))(
    (la _. print("kernel executed from bytes"))(RUN_BYTES_PROGRAM(PARSE_PROGRAM(read_file("kernel.la")))))
))(
    # The stack machine (S/E/C/D) executes a compiled program with no host
    # recursion over the program shape — control lives on the explicit
    # stacks. Same program as above, same result; then a program that
    # exercises both precompiled machine booleans (-> "TF").
    SEQ(print("--- stack machine: compiled program ---"))(
    SEQ(print(UNWRAP_STR(RUN_SM_PROGRAM(PARSE_PROGRAM(VM_SRC)))))(
    print(UNWRAP_STR(RUN_SM_PROGRAM(PARSE_PROGRAM(BOOL_SRC))))))
))(
    # The kernel on the stack machine: it speaks the Word and replicates,
    # driven entirely by the explicit operand/control/dump stacks.
    SEQ(print("--- kernel.la on the stack machine (speaks + replicates) ---"))(
    (la _. print("kernel ran on the stack machine"))(RUN_SM_PROGRAM(PARSE_PROGRAM(read_file("kernel.la")))))
)
