# ═══════════════════════════════════════════════════════════════════
#  eval.la — self-hosted evaluator for Lingua Adamica
#
#  The self-hosting loop, closed:
#    1. read a .la program from disk          (host built-in)
#    2. parse it with a parser written in LA   (parser glyphs below)
#    3. evaluate it with an evaluator in LA    (EVAL glyph below)
#
#  The language interprets itself.  When it evaluates kernel.la, it
#  speaks the Word and replicates — same as the C host, but one meta-
#  level up: the evaluator calls the host's print and copy_self to
#  produce real effects.
#
#  Value encoding (Scott, 4-branch):
#    VAL_STR(s)            — a string
#    VAL_CLO(p)(body)(env) — a closure  (param name, AST body, captured env)
#    VAL_BI(name)          — a builtin waiting for its first argument
#    VAL_PA(name)(v)       — a curried builtin with its first argument captured
# ═══════════════════════════════════════════════════════════════════

# ── 1. Foundations ──────────────────────────────────────────────────

glyph TRUE  = la t. la f. t
glyph FALSE = la t. la f. f
glyph ID    = la x. x
glyph SEQ   = la a. la b. b

glyph Z  = la f. (la x. f(la v. x(x)(v)))(la x. f(la v. x(x)(v)))
glyph IF = la cond. la t. la f. cond(t)(f)("!")

glyph PAIR = la a. la b. la f. f(a)(b)
glyph FST  = la p. p(la a. la b. a)
glyph SND  = la p. p(la a. la b. b)

glyph NONE    = PAIR(FALSE)("")
glyph SOME    = la val. la rest. PAIR(TRUE)(PAIR(val)(rest))
glyph IS_SOME = la r. FST(r)
glyph R_VAL   = la r. FST(SND(r))
glyph R_REST  = la r. SND(SND(r))

glyph NIL      = PAIR(FALSE)("")
glyph CONS     = la h. la t. PAIR(TRUE)(PAIR(h)(t))
glyph IS_CONS  = la lst. FST(lst)
glyph LIST_HD  = la lst. FST(SND(lst))
glyph LIST_TL  = la lst. SND(SND(lst))

# ── 2. AST constructors ────────────────────────────────────────────
#  node(on_var)(on_lam)(on_app)(on_str)

glyph AST_VAR = la name. la v. la l. la a. la s. v(name)
glyph AST_LAM = la param. la body. la v. la l. la a. la s. l(param)(body)
glyph AST_APP = la func. la arg. la v. la l. la a. la s. a(func)(arg)
glyph AST_STR = la val. la v. la l. la a. la s. s(val)

# ── 3. Lexer ────────────────────────────────────────────────────────

glyph IS_SPACE = la c. IF(str_eq(c)(" "))(la _. TRUE)(la _. IF(str_eq(c)("\n"))(la _. TRUE)(la _. IF(str_eq(c)("\t"))(la _. TRUE)(la _. FALSE)))

glyph IS_SPECIAL = la c. IF(str_eq(c)("("))(la _. TRUE)(la _. IF(str_eq(c)(")"))(la _. TRUE)(la _. IF(str_eq(c)("."))(la _. TRUE)(la _. IF(str_eq(c)("="))(la _. TRUE)(la _. FALSE))))

glyph IS_QUOTE_OR_HASH = la c. IF(str_eq(c)("\""))(la _. TRUE)(la _. IF(str_eq(c)("#"))(la _. TRUE)(la _. FALSE))

glyph IS_IDENT_CHAR = la c. IF(str_eq(c)(""))(la _. FALSE)(la _. IF(IS_SPACE(c))(la _. FALSE)(la _. IF(IS_SPECIAL(c))(la _. FALSE)(la _. IF(IS_QUOTE_OR_HASH(c))(la _. FALSE)(la _. TRUE))))

glyph SKIP_LINE = Z(la self. la s. IF(str_eq(s)(""))(la _. s)(la _. IF(str_eq(str_head(s))("\n"))(la _. str_tail(s))(la _. self(str_tail(s)))))

glyph SKIP_SPACES = Z(la self. la s. IF(str_eq(s)(""))(la _. s)(la _. IF(IS_SPACE(str_head(s)))(la _. self(str_tail(s)))(la _. IF(str_eq(str_head(s))("#"))(la _. self(SKIP_LINE(s)))(la _. s))))

glyph READ_IDENT = Z(la self. la acc. la s. IF(IS_IDENT_CHAR(str_head(s)))(la _. self(concat(acc)(str_head(s)))(str_tail(s)))(la _. PAIR(acc)(s)))

# A digit is one of "0".."9". Defined with str_eq only (no int builtins),
# so the same lexer runs unchanged on the native VM, which has str_eq but
# not lt/str_to_int.
glyph IS_DIGIT = la c. IF(str_eq(c)("0"))(la _. TRUE)(la _. IF(str_eq(c)("1"))(la _. TRUE)(la _. IF(str_eq(c)("2"))(la _. TRUE)(la _. IF(str_eq(c)("3"))(la _. TRUE)(la _. IF(str_eq(c)("4"))(la _. TRUE)(la _. IF(str_eq(c)("5"))(la _. TRUE)(la _. IF(str_eq(c)("6"))(la _. TRUE)(la _. IF(str_eq(c)("7"))(la _. TRUE)(la _. IF(str_eq(c)("8"))(la _. TRUE)(la _. IF(str_eq(c)("9"))(la _. TRUE)(la _. FALSE))))))))))
glyph READ_INT = Z(la self. la acc. la s. IF(IS_DIGIT(str_head(s)))(la _. self(concat(acc)(str_head(s)))(str_tail(s)))(la _. PAIR(acc)(s)))

glyph UNESCAPE = la c. IF(str_eq(c)("n"))(la _. "\n")(la _. IF(str_eq(c)("t"))(la _. "\t")(la _. c))

glyph READ_STRING = Z(la self. la acc. la s. IF(str_eq(s)(""))(la _. PAIR(acc)(s))(la _. IF(str_eq(str_head(s))("\""))(la _. PAIR(acc)(str_tail(s)))(la _. IF(str_eq(str_head(s))("\\"))(la _. self(concat(acc)(UNESCAPE(str_head(str_tail(s)))))(str_tail(str_tail(s))))(la _. self(concat(acc)(str_head(s)))(str_tail(s))))))

glyph TOK_TYPE = la tok. FST(tok)
glyph TOK_VAL  = la tok. SND(tok)
glyph MKTOK    = la ty. la val. PAIR(ty)(val)

glyph LEX_ONE = la s. IF(str_eq(s)(""))(la _. PAIR(MKTOK("eof")(""))(s))(la _. IF(str_eq(str_head(s))("("))(la _. PAIR(MKTOK("lp")("("))(str_tail(s)))(la _. IF(str_eq(str_head(s))(")"))(la _. PAIR(MKTOK("rp")(")"))(str_tail(s)))(la _. IF(str_eq(str_head(s))("."))(la _. PAIR(MKTOK("dot")("."))(str_tail(s)))(la _. IF(str_eq(str_head(s))("="))(la _. PAIR(MKTOK("eq")("="))(str_tail(s)))(la _. IF(str_eq(str_head(s))("\""))(la _. (la r. PAIR(MKTOK("str")(FST(r)))(SND(r)))(READ_STRING("")(str_tail(s))))(la _. IF(IS_DIGIT(str_head(s)))(la _. (la r. PAIR(MKTOK("int")(FST(r)))(SND(r)))(READ_INT("")(s)))(la _. IF(IS_IDENT_CHAR(str_head(s)))(la _. (la r. (la name. (la rest. IF(str_eq(name)("glyph"))(la _. PAIR(MKTOK("glyph")("glyph"))(rest))(la _. IF(str_eq(name)("la"))(la _. PAIR(MKTOK("la")("la"))(rest))(la _. IF(str_eq(name)("import"))(la _. PAIR(MKTOK("import")("import"))(rest))(la _. IF(str_eq(name)("export"))(la _. PAIR(MKTOK("export")("export"))(rest))(la _. PAIR(MKTOK("ident")(name))(rest))))))(SND(r)))(FST(r)))(READ_IDENT("")(s)))(la _. PAIR(MKTOK("eof")(""))(s)))))))))

glyph NEXT_TOKEN = la s. LEX_ONE(SKIP_SPACES(s))

# ── 4. Parser ───────────────────────────────────────────────────────

glyph PARSE_PRIMARY = la s. (la tr. (la tok. (la rest. IF(str_eq(TOK_TYPE(tok))("ident"))(la _. SOME(AST_VAR(TOK_VAL(tok)))(rest))(la _. IF(str_eq(TOK_TYPE(tok))("str"))(la _. SOME(AST_STR(TOK_VAL(tok)))(rest))(la _. IF(str_eq(TOK_TYPE(tok))("int"))(la _. SOME(AST_APP(AST_VAR("str_to_int"))(AST_STR(TOK_VAL(tok))))(rest))(la _. IF(str_eq(TOK_TYPE(tok))("lp"))(la _. (la inner. IF(IS_SOME(inner))(la _. (la tr2. (la tok2. (la rest2. IF(str_eq(TOK_TYPE(tok2))("rp"))(la _. SOME(R_VAL(inner))(rest2))(la _. NONE))(SND(tr2)))(FST(tr2)))(NEXT_TOKEN(R_REST(inner))))(la _. NONE))(PARSE_EXPR(rest)))(la _. NONE)))))(SND(tr)))(FST(tr)))(NEXT_TOKEN(s))

glyph PARSE_APP_TAIL = Z(la self. la acc. la s. (la tr. (la tok. (la rest. IF(str_eq(TOK_TYPE(tok))("lp"))(la _. (la arg. IF(IS_SOME(arg))(la _. (la tr2. (la tok2. (la rest2. IF(str_eq(TOK_TYPE(tok2))("rp"))(la _. self(AST_APP(acc)(R_VAL(arg)))(rest2))(la _. NONE))(SND(tr2)))(FST(tr2)))(NEXT_TOKEN(R_REST(arg))))(la _. NONE))(PARSE_EXPR(rest)))(la _. SOME(acc)(s)))(SND(tr)))(FST(tr)))(NEXT_TOKEN(s)))

glyph PARSE_APP = la s. (la base. IF(IS_SOME(base))(la _. PARSE_APP_TAIL(R_VAL(base))(R_REST(base)))(la _. NONE))(PARSE_PRIMARY(s))

glyph PARSE_EXPR = Z(la self_expr. la s. (la tr. (la tok. (la rest. IF(str_eq(TOK_TYPE(tok))("la"))(la _. (la tr2. (la tok2. (la rest2. IF(str_eq(TOK_TYPE(tok2))("ident"))(la _. (la tr3. (la tok3. (la rest3. IF(str_eq(TOK_TYPE(tok3))("dot"))(la _. (la body. IF(IS_SOME(body))(la _. SOME(AST_LAM(TOK_VAL(tok2))(R_VAL(body)))(R_REST(body)))(la _. NONE))(self_expr(rest3)))(la _. NONE))(SND(tr3)))(FST(tr3)))(NEXT_TOKEN(rest2)))(la _. NONE))(SND(tr2)))(FST(tr2)))(NEXT_TOKEN(rest)))(la _. PARSE_APP(s)))(SND(tr)))(FST(tr)))(NEXT_TOKEN(s)))

glyph PARSE_GLYPH = la s. (la tr. (la tok. (la rest. IF(str_eq(TOK_TYPE(tok))("glyph"))(la _. (la tr2. (la tok2. (la rest2. IF(str_eq(TOK_TYPE(tok2))("ident"))(la _. (la tr3. (la tok3. (la rest3. IF(str_eq(TOK_TYPE(tok3))("eq"))(la _. (la body. IF(IS_SOME(body))(la _. SOME(PAIR(TOK_VAL(tok2))(R_VAL(body)))(R_REST(body)))(la _. NONE))(PARSE_EXPR(rest3)))(la _. NONE))(SND(tr3)))(FST(tr3)))(NEXT_TOKEN(rest2)))(la _. NONE))(SND(tr2)))(FST(tr2)))(NEXT_TOKEN(rest)))(la _. NONE))(SND(tr)))(FST(tr)))(NEXT_TOKEN(s))

# ── 4b. Module system (import / export) ─────────────────────────────
#
# import/export are resolved at PARSE time, exactly as the C host does:
# the result is a single flat glyph table with the imported module's
# PRIVATE glyphs alpha-renamed away. EVAL never sees import/export — they
# are pure generation, fully discharged before any recognition runs.
#
# Mangling is PATH-DERIVED (deterministic, reproducible across engines):
# a private glyph `g` of module `p` becomes `__mod_<sanitize p>__g`, and
# every reference to it WITHIN the module is rewritten to match. Exports
# keep their plain names; the importer's own glyphs are untouched.

# Generic list helpers (string membership; order-preserving concat).
glyph APPEND     = Z(la self. la a. la b. IF(IS_CONS(a))(la _. CONS(LIST_HD(a))(self(LIST_TL(a))(b)))(la _. b))
glyph STR_MEMBER = Z(la self. la x. la lst. IF(IS_CONS(lst))(la _. IF(str_eq(x)(LIST_HD(lst)))(la _. TRUE)(la _. self(x)(LIST_TL(lst))))(la _. FALSE))

# RENAME_FREE(ast)(old)(new): rewrite every FREE occurrence of variable
# `old` to `new`, stopping under a lambda that rebinds `old`. `new` is
# always a fresh __mod_ name, so it can never be captured — only shadowing
# of `old` needs care (the LAM branch). This is the AST-rewrite the C host
# gets from its capture-avoiding subst; here `new` fresh makes it simpler.
glyph RENAME_FREE = Z(la self. la node. la old. la new.
    node
        (la name. IF(str_eq(name)(old))(la _. AST_VAR(new))(la _. AST_VAR(name)))
        (la p. la b. IF(str_eq(p)(old))(la _. AST_LAM(p)(b))(la _. AST_LAM(p)(self(b)(old)(new))))
        (la f. la a. AST_APP(self(f)(old)(new))(self(a)(old)(new)))
        (la val. AST_STR(val)))

# Path → ident-safe prefix component: every non-ident char becomes "_".
glyph SANITIZE = Z(la self. la s. IF(str_eq(s)(""))(la _. "")(la _.
    concat(IF(IS_IDENT_CHAR(str_head(s)))(la _. str_head(s))(la _. "_"))(self(str_tail(s)))))

glyph MANGLE = la path. la name. concat("__mod_")(concat(SANITIZE(path))(concat("__")(name)))

# A module's private names = entry names not in its export list.
glyph PRIVATE_NAMES = Z(la self. la table. la exports.
    IF(IS_CONS(table))(la _.
        (la nm. IF(STR_MEMBER(nm)(exports))(la _. self(LIST_TL(table))(exports))(la _. CONS(nm)(self(LIST_TL(table))(exports))))(FST(LIST_HD(table)))
    )(la _. NIL))

# Rewrite every private reference inside one body (fold RENAME_FREE).
glyph MANGLE_BODY = Z(la self. la ast. la privs. la path.
    IF(IS_CONS(privs))(la _.
        (la p. self(RENAME_FREE(ast)(p)(MANGLE(path)(p)))(LIST_TL(privs))(path))(LIST_HD(privs))
    )(la _. ast))

# Map the whole module table: rename private keys, rewrite all bodies.
glyph MANGLE_MAP = Z(la self. la table. la exports. la privs. la path.
    IF(IS_CONS(table))(la _.
        (la entry. (la nm. (la ast.
            CONS(PAIR(IF(STR_MEMBER(nm)(exports))(la _. nm)(la _. MANGLE(path)(nm)))(MANGLE_BODY(ast)(privs)(path)))(self(LIST_TL(table))(exports)(privs)(path))
        )(SND(entry)))(FST(entry)))(LIST_HD(table))
    )(la _. NIL))

glyph MANGLE_MODULE = la table. la exports. la path.
    MANGLE_MAP(table)(exports)(PRIVATE_NAMES(table)(exports))(path)

# Parse `import ( "path" )` just after the `import` keyword → PAIR(path)(rest).
glyph PARSE_IMPORT = la s. (la tr. (la tok. (la rest.
    IF(str_eq(TOK_TYPE(tok))("lp"))(la _.
        (la tr2. (la tok2. (la rest2.
            IF(str_eq(TOK_TYPE(tok2))("str"))(la _.
                (la tr3. (la tok3. (la rest3.
                    IF(str_eq(TOK_TYPE(tok3))("rp"))(la _. PAIR(TOK_VAL(tok2))(rest3))(la _. error(concat("eval: import: expected ) near: ")(rest2)))
                )(SND(tr3)))(FST(tr3)))(NEXT_TOKEN(rest2))
            )(la _. error(concat("eval: import: expected path string near: ")(rest)))
        )(SND(tr2)))(FST(tr2)))(NEXT_TOKEN(rest))
    )(la _. error(concat("eval: import: expected ( near: ")(s)))
)(SND(tr)))(FST(tr)))(NEXT_TOKEN(s))

# Parse a run of `export` names just after the `export` keyword. Stops at
# the first non-ident token WITHOUT consuming it → PAIR(names)(rest).
glyph PARSE_EXPORT_NAMES = Z(la self. la s. (la tr. (la tok. (la rest.
    IF(str_eq(TOK_TYPE(tok))("ident"))(la _.
        (la recpair. PAIR(CONS(TOK_VAL(tok))(FST(recpair)))(SND(recpair)))(self(rest))
    )(la _. PAIR(NIL)(s))
)(SND(tr)))(FST(tr)))(NEXT_TOKEN(s)))

# Top-level loop: dispatch over glyph / import / export in source order,
# accumulating PAIR(glyph_table)(export_list). import reads + recursively
# parses the module, mangles its privates, and appends the merged table.
glyph PARSE_MOD_LOOP = Z(la self. la s.
    (la s2. IF(str_eq(s2)(""))(la _. PAIR(NIL)(NIL))(la _.
        (la tr. (la tok. (la rest.
            IF(str_eq(TOK_TYPE(tok))("glyph"))(la _.
                (la g. IF(IS_SOME(g))(la _.
                    (la recpair. PAIR(CONS(R_VAL(g))(FST(recpair)))(SND(recpair)))(self(R_REST(g)))
                )(la _. error(concat("eval: parse error near: ")(s2))))(PARSE_GLYPH(s2))
            )(la _.
            IF(str_eq(TOK_TYPE(tok))("import"))(la _.
                (la ip. (la modpair. (la mangled. (la recpair.
                    PAIR(APPEND(mangled)(FST(recpair)))(SND(recpair))
                )(self(SND(ip))))(MANGLE_MODULE(FST(modpair))(SND(modpair))(FST(ip))))(PARSE_MODULE(read_file(FST(ip)))))(PARSE_IMPORT(rest))
            )(la _.
            IF(str_eq(TOK_TYPE(tok))("export"))(la _.
                (la ep. (la recpair. PAIR(FST(recpair))(APPEND(FST(ep))(SND(recpair))))(self(SND(ep))))(PARSE_EXPORT_NAMES(rest))
            )(la _.
                error(concat("eval: parse error near: ")(s2))
            )))
        )(SND(tr)))(FST(tr)))(NEXT_TOKEN(s2))
    ))(SKIP_SPACES(s)))

glyph PARSE_MODULE = la s. PARSE_MOD_LOOP(s)

# PARSE_PROGRAM keeps its old type (source → glyph table); the export list
# of the top-level program is discarded (only importers consume exports).
glyph PARSE_PROGRAM = la s. FST(PARSE_MODULE(s))

# ── 5. Value types ──────────────────────────────────────────────────
#  val(on_str)(on_clo)(on_bi)(on_pa)

glyph VAL_STR = la s.    la os. la oc. la ob. la op. la oi. os(s)
glyph VAL_CLO = la p. la body. la env. la os. la oc. la ob. la op. la oi. oc(p)(body)(env)
glyph VAL_BI  = la name. la os. la oc. la ob. la op. la oi. ob(name)
glyph VAL_PA  = la name. la v.  la os. la oc. la ob. la op. la oi. op(name)(v)
glyph VAL_INT = la n.    la os. la oc. la ob. la op. la oi. oi(n)

# Strict: a string is itself; an integer coerces to its decimal (so print
# works); a closure / builtin / partial is a type error and halts, instead
# of silently degrading to "".
glyph UNWRAP_STR = la val. val (la s. s) (la p. la b. la e. error("eval: expected a string, got a closure")) (la n. error("eval: expected a string, got a builtin")) (la n. la v. error("eval: expected a string, got a partial")) (la n. int_to_str(n))
glyph UNWRAP_INT = la val. val (la s. 0) (la p. la b. la e. 0) (la n. 0) (la n. la v. 0) (la n. n)

# Church booleans as meta-level closures: when the object program's
# str_eq returns TRUE/FALSE, these ARE the values — closures whose
# bodies are the Church boolean ASTs, so applying them selects a branch.
glyph META_TRUE  = VAL_CLO("t")(AST_LAM("f")(AST_VAR("t")))(NIL)
glyph META_FALSE = VAL_CLO("t")(AST_LAM("f")(AST_VAR("f")))(NIL)

# ── 6. Lookup ───────────────────────────────────────────────────────

# Search a list of PAIR(name)(value) entries by name.
# Returns SOME(value)("") or NONE.
glyph LIST_FIND = Z(la self. la name. la lst.
    IF(IS_CONS(lst))(la _.
        (la entry.
            IF(str_eq(name)(FST(entry)))(la _.
                SOME(SND(entry))("")
            )(la _.
                self(name)(LIST_TL(lst))
            )
        )(LIST_HD(lst))
    )(la _. NONE))

glyph IS_BI_NAME = la name.
    IF(str_eq(name)("print"))(la _. TRUE)(la _.
    IF(str_eq(name)("copy_self"))(la _. TRUE)(la _.
    IF(str_eq(name)("read_file"))(la _. TRUE)(la _.
    IF(str_eq(name)("write_file"))(la _. TRUE)(la _.
    IF(str_eq(name)("concat"))(la _. TRUE)(la _.
    IF(str_eq(name)("str_head"))(la _. TRUE)(la _.
    IF(str_eq(name)("str_tail"))(la _. TRUE)(la _.
    IF(str_eq(name)("str_eq"))(la _. TRUE)(la _.
    IF(str_eq(name)("str_len"))(la _. TRUE)(la _.
    IF(str_eq(name)("add"))(la _. TRUE)(la _.
    IF(str_eq(name)("sub"))(la _. TRUE)(la _.
    IF(str_eq(name)("mul"))(la _. TRUE)(la _.
    IF(str_eq(name)("div"))(la _. TRUE)(la _.
    IF(str_eq(name)("mod"))(la _. TRUE)(la _.
    IF(str_eq(name)("lt"))(la _. TRUE)(la _.
    IF(str_eq(name)("int_eq"))(la _. TRUE)(la _.
    IF(str_eq(name)("int_to_str"))(la _. TRUE)(la _.
    IF(str_eq(name)("str_to_int"))(la _. TRUE)(la _.
    FALSE))))))))))))))))))

# ── 7. Built-in dispatch ───────────────────────────────────────────
#
# These bridge the meta-level and the host: when the object program
# calls print("hello"), the evaluator calls the HOST's print, which
# actually writes to stdout.  The language's effects pass through.

glyph APPLY_BI = la name. la val.
    IF(str_eq(name)("print"))(la _.
        (la s. (la _. val)(print(s)))(UNWRAP_STR(val))
    )(la _.
    IF(str_eq(name)("copy_self"))(la _.
        # val is already forced (for effect ordering); the host copy_self
        # ignores its argument, so pass a literal rather than UNWRAP_STR(val)
        # — val is typically a closure (SELF = ∃(∃)), not a string.
        (la path. VAL_STR(path))(copy_self("self"))
    )(la _.
    IF(str_eq(name)("read_file"))(la _.
        VAL_STR(read_file(UNWRAP_STR(val)))
    )(la _.
    IF(str_eq(name)("write_file"))(la _.
        VAL_PA("write_file")(val)
    )(la _.
    IF(str_eq(name)("concat"))(la _.
        VAL_PA("concat")(val)
    )(la _.
    IF(str_eq(name)("str_head"))(la _.
        VAL_STR(str_head(UNWRAP_STR(val)))
    )(la _.
    IF(str_eq(name)("str_tail"))(la _.
        VAL_STR(str_tail(UNWRAP_STR(val)))
    )(la _.
    IF(str_eq(name)("str_len"))(la _.
        VAL_STR(str_len(UNWRAP_STR(val)))
    )(la _.
    IF(str_eq(name)("str_eq"))(la _.
        VAL_PA("str_eq")(val)
    )(la _.
    IF(str_eq(name)("int_to_str"))(la _. VAL_STR(int_to_str(UNWRAP_INT(val))))(la _.
    IF(str_eq(name)("str_to_int"))(la _. VAL_INT(str_to_int(UNWRAP_STR(val))))(la _.
    IF(str_eq(name)("add"))(la _. VAL_PA("add")(val))(la _.
    IF(str_eq(name)("sub"))(la _. VAL_PA("sub")(val))(la _.
    IF(str_eq(name)("mul"))(la _. VAL_PA("mul")(val))(la _.
    IF(str_eq(name)("div"))(la _. VAL_PA("div")(val))(la _.
    IF(str_eq(name)("mod"))(la _. VAL_PA("mod")(val))(la _.
    IF(str_eq(name)("lt"))(la _. VAL_PA("lt")(val))(la _.
    IF(str_eq(name)("int_eq"))(la _. VAL_PA("int_eq")(val))(la _.
        error(concat("eval: unknown builtin: ")(name))
    ))))))))))))))))))

glyph APPLY_BI2 = la name. la v1. la v2.
    IF(str_eq(name)("write_file"))(la _.
        (la _. v2)(write_file(UNWRAP_STR(v1))(UNWRAP_STR(v2)))
    )(la _.
    IF(str_eq(name)("concat"))(la _.
        VAL_STR(concat(UNWRAP_STR(v1))(UNWRAP_STR(v2)))
    )(la _.
    IF(str_eq(name)("str_eq"))(la _.
        IF(str_eq(UNWRAP_STR(v1))(UNWRAP_STR(v2)))(la _. META_TRUE)(la _. META_FALSE)
    )(la _.
    IF(str_eq(name)("add"))(la _. VAL_INT(add(UNWRAP_INT(v1))(UNWRAP_INT(v2))))(la _.
    IF(str_eq(name)("sub"))(la _. VAL_INT(sub(UNWRAP_INT(v1))(UNWRAP_INT(v2))))(la _.
    IF(str_eq(name)("mul"))(la _. VAL_INT(mul(UNWRAP_INT(v1))(UNWRAP_INT(v2))))(la _.
    IF(str_eq(name)("div"))(la _. VAL_INT(div(UNWRAP_INT(v1))(UNWRAP_INT(v2))))(la _.
    IF(str_eq(name)("mod"))(la _. VAL_INT(mod(UNWRAP_INT(v1))(UNWRAP_INT(v2))))(la _.
    IF(str_eq(name)("lt"))(la _. IF(lt(UNWRAP_INT(v1))(UNWRAP_INT(v2)))(la _. META_TRUE)(la _. META_FALSE))(la _.
    IF(str_eq(name)("int_eq"))(la _. IF(int_eq(UNWRAP_INT(v1))(UNWRAP_INT(v2)))(la _. META_TRUE)(la _. META_FALSE))(la _.
        error(concat("eval: unknown builtin2: ")(name))
    ))))))))))

# ── 8. The evaluator ───────────────────────────────────────────────
#
# EVAL(ast)(env)(gl) → value
#
#   ast  : a Scott-encoded AST node from the parser
#   env  : a list of PAIR(name)(value) — the local environment
#   gl   : a list of PAIR(name)(ast)   — the parsed glyph table
#
# The evaluator is closure-based: lambdas capture their defining
# environment, and application extends the closure's environment.
# This is semantically equivalent to the C host's substitution-based
# evaluator, but avoids the complexity of capture-avoiding substitution.

glyph EVAL = Z(la self. la ast. la env. la gl.
    ast
        # ── VAR(name) ──
        # Look up in local env first, then glyph table, then builtins.
        (la name.
            (la local.
                IF(IS_SOME(local))(la _.
                    R_VAL(local)
                )(la _.
                (la found.
                    IF(IS_SOME(found))(la _.
                        self(R_VAL(found))(NIL)(gl)
                    )(la _.
                    IF(IS_BI_NAME(name))(la _.
                        VAL_BI(name)
                    )(la _.
                        error(concat("eval: unbound variable: ")(name))
                    ))
                )(LIST_FIND(name)(gl)))
            )(LIST_FIND(name)(env))
        )
        # ── LAM(param, body) ──
        # Capture the current environment in a closure.
        (la param. la body.
            VAL_CLO(param)(body)(env)
        )
        # ── APP(func, arg) ──
        # Evaluate the function, then dispatch on the value type.
        (la func. la arg.
            (la fval.
                fval
                    # VAL_STR — cannot apply a string
                    (la s.
                        error(concat("eval: cannot apply string: ")(s))
                    )
                    # VAL_CLO — beta reduction via environment extension
                    (la p. la b. la e.
                        (la aval.
                            self(b)(CONS(PAIR(p)(aval))(e))(gl)
                        )(self(arg)(env)(gl))
                    )
                    # VAL_BI — first application of a builtin
                    (la biname.
                        APPLY_BI(biname)(self(arg)(env)(gl))
                    )
                    # VAL_PA — second application of a curried builtin
                    (la paname. la pv.
                        APPLY_BI2(paname)(pv)(self(arg)(env)(gl))
                    )
                    # VAL_INT — cannot apply an integer
                    (la n.
                        error(concat("eval: cannot apply integer: ")(int_to_str(n)))
                    )
            )(self(func)(env)(gl))
        )
        # ── STR(val) ──
        # Strings are values.
        (la val. VAL_STR(val))
)

# ── 9. Runner ───────────────────────────────────────────────────────
#
# RUN_GLYPH(name)(gl) — find a named glyph in the table and evaluate it.
# RUN(gl)             — the common case: evaluate MAIN.

glyph RUN_GLYPH = la name. la gl.
    (la found.
        IF(IS_SOME(found))(la _.
            EVAL(R_VAL(found))(NIL)(gl)
        )(la _.
            error(concat("eval: no glyph: ")(name))
        )
    )(LIST_FIND(name)(gl))

glyph RUN = la gl. RUN_GLYPH("MAIN")(gl)

# ── 9b. Unparser — the dual of the parser ──────────────────────────
#
# SHOW_SRC(node) turns an AST back into Lingua Adamica source text.
# It is the exact inverse of the parser: PARSE_PROGRAM reads source
# into ASTs, SHOW_SRC writes ASTs back into source. Composed, they
# round-trip — parse then unparse reproduces the original definition.
#
# Re-escape string literals so the printed source re-lexes faithfully.
# Each source string below denotes a *value*: "\\\\" is one backslash
# turned into two, "\\\"" is the two characters \ and " , and so on.

glyph ESC_CHAR = la c.
    IF(str_eq(c)("\\"))(la _. "\\\\")(la _.
    IF(str_eq(c)("\""))(la _. "\\\"")(la _.
    IF(str_eq(c)("\n"))(la _. "\\n")(la _.
    IF(str_eq(c)("\t"))(la _. "\\t")(la _.
    c))))

glyph ESCAPE = Z(la self. la s.
    IF(str_eq(s)(""))(la _. "")(la _.
        concat(ESC_CHAR(str_head(s)))(self(str_tail(s)))))

# SHOW_FUN_POS(rec)(f) — render f for the function side of an
# application. A lambda there must be parenthesised, `(la x. ...)`;
# variables, applications, and strings need no extra parentheses.
glyph SHOW_FUN_POS = la rec. la f.
    f
        (la name. rec(f))
        (la p. la b. concat("(")(concat(rec(f))(")")))
        (la g. la a. rec(f))
        (la val. rec(f))

# SHOW_SRC(node) — unparse an AST node to source.
glyph SHOW_SRC = Z(la self. la node.
    node
        (la name. name)
        (la p. la b. concat("la ")(concat(p)(concat(". ")(self(b)))))
        (la f. la arg. concat(SHOW_FUN_POS(self)(f))(concat("(")(concat(self(arg))(")"))))
        (la val. concat("\"")(concat(ESCAPE(val))("\"")))
)

# SHOW_PROGRAM(gl) — unparse a whole glyph table back into a program.
# Each entry is PAIR(name)(ast); emit `glyph NAME = EXPR` per line, in
# order. This is the inverse of PARSE_PROGRAM at the program level.
glyph SHOW_PROGRAM = Z(la self. la gl.
    IF(IS_CONS(gl))(la _.
        (la entry.
            concat("glyph ")(concat(FST(entry))(concat(" = ")(concat(SHOW_SRC(SND(entry)))(concat("\n")(self(LIST_TL(gl)))))))
        )(LIST_HD(gl))
    )(la _. ""))

# ── INNER — reconstructs the whole of eval.la ──────────────────────
#
# INNER takes a parsed glyph table and rebuilds the entire program
# source from it.  In the self-test it is handed the table parsed from
# eval.la's own source, so it reconstructs the whole of eval.la — every
# glyph, in order, in canonical (comment-free, one-line) form.  eval.la's
# parser parses all of eval.la, and eval.la's unparser writes it all back.
# Comments and original spacing are not source data, so the reconstruction
# is a normalised form rather than a byte copy; its faithfulness is shown
# by a fixed point: re-parsing the reconstruction and reconstructing again
# reproduces it exactly (parse ∘ unparse is idempotent on the program).

glyph INNER = la gl. SHOW_PROGRAM(gl)

# ── 10. Tests ───────────────────────────────────────────────────────

# Smoke test: a trivial program
glyph TEST1_SRC = "glyph MAIN = print(\"hello from the meta-evaluator\")\n"

# Lambda + application test
glyph TEST2_SRC = "glyph ID = la x. x\nglyph MAIN = print(ID(\"identity works\"))\n"

# Curried builtin test
glyph TEST3_SRC = "glyph MAIN = print(concat(\"con\")(\"cat\"))\n"

# Native-integer test: arithmetic via the meta-evaluator. Cross-engine:
# the same program run by the C host must produce the identical output.
glyph TEST6_SRC = "glyph MAIN = print(int_to_str(add(mul(6)(7))(sub(10)(8))))\n"

glyph MAIN = SEQ(SEQ(SEQ(SEQ(SEQ(
    # Test 1: trivial program
    SEQ(print("--- test 1: print ---"))(
    RUN(PARSE_PROGRAM(TEST1_SRC)))
)(
    # Test 2: lambda + application
    SEQ(print("--- test 2: lambda ---"))(
    RUN(PARSE_PROGRAM(TEST2_SRC)))
))(
    # Test 3: curried builtin
    SEQ(print("--- test 3: concat ---"))(
    RUN(PARSE_PROGRAM(TEST3_SRC)))
))(
    # Test 4: the real thing — parse and evaluate kernel.la
    SEQ(print("--- test 4: kernel.la ---"))(
    RUN(PARSE_PROGRAM(read_file("kernel.la"))))
))(
    # Test 5: the closed eye — INNER reconstructs the WHOLE of eval.la.
    # Read eval.la, parse it with eval.la's own parser into a glyph table,
    # and hand the whole table to INNER, which unparses every glyph back
    # into source. The result is eval.la rebuilt from its own AST. We
    # write it to eval_reconstructed.la, then prove it faithful by a fixed
    # point: re-parse the reconstruction and reconstruct again — parse ∘
    # unparse is idempotent on the whole program (comments aside).
    SEQ(print("--- test 5: INNER reconstructs the whole of eval.la ---"))(
    (la recon1.
        SEQ(write_file("eval_reconstructed.la")(recon1))(
        SEQ(print(recon1))(
        (la recon2.
            print(str_eq(recon1)(recon2)("round-trip: stable")("round-trip: DIVERGED"))
        )(INNER(PARSE_PROGRAM(recon1)))))
    )(INNER(PARSE_PROGRAM(read_file("eval.la")))))
))(
    # Test 6: integers — same program the C host runs (cross-engine check)
    SEQ(print("--- test 6: integers ---"))(
    RUN(PARSE_PROGRAM(TEST6_SRC))))
