# BEING : a -> a   (identity; ∃, the axiom ∃(∃) ≡ ∃)
glyph BEING = la self. self
# Z : (a -> a) -> a   (fixpoint combinator, support)
glyph Z = la f. (la x. f(la v. x(x)(v)))(la x. f(la v. x(x)(v)))
# RELATION : a -> b -> (a -> b -> c) -> c   (the bare two-place link)
glyph RELATION = la a. la b. la f. f(a)(b)
# RECOGNITION : a -> (a paired with itself)   (reflexive relation, T ≡ R)
glyph RECOGNITION = la x. RELATION(x)(x)
# LOVE : a -> b -> reciprocal pairs   (symmetric union / reciprocity)
glyph LOVE = la a. la b. RELATION(RELATION(a)(b))(RELATION(b)(a))
