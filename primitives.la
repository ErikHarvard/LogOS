glyph VOID = la a. la b. b
# BECOMING : Nat -> Nat   (successor — the engine of becoming)
glyph BECOMING = la n. la f. la x. f(n(f)(x))
# FORM : a -> (a -> b) -> b   (the seal — determinate, key-accessed structure)
glyph FORM = la x. la k. k(x)
